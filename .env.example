AI_PROVIDER=auto
OLLAMA_BASE_URL=https://ollama.com/api
OLLAMA_MODEL=glm-5:cloud
# Optional: required for scanned/image-only PDF selections.
# Ollama's vision docs use gemma4 as the image-capable example model.
# OLLAMA_VISION_MODEL=gemma4

# Required for ollama.com cloud API:
# OLLAMA_API_KEY=your_ollama_api_key_here

# Optional fallbacks:
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-3-flash-preview

# GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.1-8b-instant
# Optional: override the OpenAI-compatible Groq endpoint.
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-5.5

# Optional cloud sync for moving local IndexedDB data between devices.
# Keep the service role key server-side only. Never expose it as NEXT_PUBLIC_*.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# SUPABASE_SYNC_BUCKET=ielts-sync
