AI_PROVIDER=ollama
OLLAMA_BASE_URL=https://ollama.com/api
OLLAMA_MODEL=glm-5:cloud
# Optional: set this to a vision-capable Ollama model for scanned/image PDF selections.
# OLLAMA_VISION_MODEL=your_vision_model_here

# Required for ollama.com cloud API:
# OLLAMA_API_KEY=your_ollama_api_key_here

# Optional fallbacks:
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-3-flash-preview

# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-5.5

# Optional cloud sync for moving local IndexedDB data between devices.
# Keep the service role key server-side only. Never expose it as NEXT_PUBLIC_*.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# SUPABASE_SYNC_BUCKET=ielts-sync
